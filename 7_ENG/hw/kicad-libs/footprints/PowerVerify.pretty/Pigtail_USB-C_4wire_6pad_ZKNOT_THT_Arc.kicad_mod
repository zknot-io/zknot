(footprint "Pigtail_USB-C_4wire_6pad_ZKNOT_THT_Arc"
	(version 20240108)
	(generator "zknot_powerverify")
	(generator_version "9.0")
	(layer "F.Cu")
	(descr "ZKNOT USB-C male pigtail termination, 4-wire 20AWG VBUS/GND + 28AWG CC1/CC2. 6 THT pads arranged on a 15mm arc centered on the cable entry point; D+/D- pads present as NC terminations for PAT-002 compliance. Strain relief: two 3mm-diameter half-moon cutouts flanking cable entry for zip tie + adhesive heat shrink. Origin = cable entry point (zip-tie anchor).")
	(tags "zknot powerverify airgap pigtail usb-c tht 20awg 100W pd patent-002")
	(property "Reference" "J**"
		(at 0 -4 0)
		(layer "F.SilkS")
		(uuid "a1b2c3d4-0000-0000-0000-000000000001")
		(effects (font (size 1 1) (thickness 0.15)))
	)

(kicad_pro
  (version 1)
  (generator "kicad")
  (general
    (kiid_path "/")
    (paper_size "A3")
  )
  (project "PV-THT-V2-CANONICAL")
  (libraries
    (pinned_symbol_libs
      (lib "PowerVerify")
    )
    (pinned_footprint_libs)
  )
  (net_settings
    (classes
      (net_class
        (name "Default")
        (wire_width 250000)
        (bus_width 120000)
        (via_diameter 800000)
        (via_drill 400000)
        (uvia_diameter 300000)
        (uvia_drill 100000)
        (diff_pair_width 200000)
        (diff_pair_gap 250000)
      )
      (net_class
        (name "Power")
        (wire_width 800000)
        (bus_width 120000)
        (via_diameter 1200000)
        (via_drill 600000)
        (uvia_diameter 300000)
        (uvia_drill 100000)
        (diff_pair_width 800000)
        (diff_pair_gap 250000)
        (nets "VBUS_IN" "VBUS" "GND")
      )
    )
  )
  (sheets
    (sheet
      (name "Root")
      (file "PV-THT-V2-CANONICAL.kicad_sch")
    )
  )
  (symbol_libs
    (lib
      (name "PowerVerify")
      (uri "${KIPRJMOD}/PowerVerify.kicad_sym")
    )
  )
  (footprint_libs)
)

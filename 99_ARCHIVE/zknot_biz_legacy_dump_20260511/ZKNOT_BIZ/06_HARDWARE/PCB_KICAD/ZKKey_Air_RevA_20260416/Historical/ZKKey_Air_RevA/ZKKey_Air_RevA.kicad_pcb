(kicad_pcb
  (version 20231120)
  (generator "pcbnew")
  (generator_version "7.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "ZKKey Air RevA")
    (date "2026-04-16")
    (rev "A")
    (company "ZKNOT, INC.")
    (comment 1 "STM32F072CBT6 + ATECC608A + GM65 + ST7789 240x240 TFT")
    (comment 2 "PAT-009 App# 63/995,740 | PAT-001 App# 63/960,933")
    (comment 3 "FULLY AIR-GAPPED — D+/D- PHYSICALLY ABSENT")
  )

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )

  (setup
    (pad_to_mask_clearance 0.1)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (subtractmaskfromsilk yes)
      (outputformat 1)
      (outputdirectory "gerbers/")
    )
  )

  ;; ============================================================
  ;; NETS
  ;; ============================================================
  (net 0 "")
  (net 1 "+5V")
  (net 2 "+3.3V")
  (net 3 "GND")
  (net 4 "VBUS")
  (net 5 "CC1_5V1K")
  (net 6 "CC2_5V1K")
  (net 7 "I2C_SCL")
  (net 8 "I2C_SDA")
  (net 9 "UART_TX")
  (net 10 "UART_RX")
  (net 11 "GM65_TRIG")
  (net 12 "SPI_SCK")
  (net 13 "SPI_MOSI")
  (net 14 "TFT_CS")
  (net 15 "TFT_DC")
  (net 16 "TFT_RST")
  (net 17 "TFT_BL")
  (net 18 "BTN_PA0")
  (net 19 "LED_PWR_PA1")
  (net 20 "LED_ARMED_PA2")
  (net 21 "LED_SIGNED_PA3")
  (net 22 "LED_ERROR_PA6")
  (net 23 "SWDIO")
  (net 24 "SWCLK")
  (net 25 "NRST")
  (net 26 "BOOT0")
  (net 27 "ATEC_ALERT")

  ;; ============================================================
  ;; BOARD OUTLINE — 80mm x 55mm landscape
  ;; Wider than Connect to accommodate GM65 module + TFT side by side
  ;; ============================================================
  (gr_rect (start 0 0) (end 80 55) (layer "Edge.Cuts") (stroke (width 0.05) (type default)))

  ;; ============================================================
  ;; MOUNTING HOLES — M3, 4 corners, 3.5mm from edge
  ;; ============================================================
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 3.5 3.5)
    (reference "H1") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 76.5 3.5)
    (reference "H2") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 3.5 51.5)
    (reference "H3") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 76.5 51.5)
    (reference "H4") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))

  ;; ============================================================
  ;; EDGE TEST POINTS — left edge, 1.5mm pads
  ;; GND 3V3 5V SCL SDA TX RX TRIG
  ;; ============================================================
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 12)
    (reference "TP1") (value "GND")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 3 "GND")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 15)
    (reference "TP2") (value "3V3")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 2 "+3.3V")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 18)
    (reference "TP3") (value "5V")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 1 "+5V")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 21)
    (reference "TP4") (value "SCL")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 7 "I2C_SCL")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 24)
    (reference "TP5") (value "SDA")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 8 "I2C_SDA")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 27)
    (reference "TP6") (value "UART_TX")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 9 "UART_TX")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 30)
    (reference "TP7") (value "UART_RX")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 10 "UART_RX")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 33)
    (reference "TP8") (value "GM65_TRIG")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 11 "GM65_TRIG")))

  ;; ============================================================
  ;; J1 — USB-C POWER-ONLY PIGTAIL — THT
  ;; VBUS + CC1 + CC2 + GND — D+/D- wires NOT PRESENT
  ;; Bottom-left, cable exits board bottom face
  ;; ============================================================
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical" (layer "F.Cu") (at 10 40)
    (reference "J1") (value "USB-C_Power_Only")
    (fp_text reference "J1" (at 0 -5) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "USB-C_PWR_ONLY" (at 0 6) (layer "F.Fab") (effects (font (size 0.7 0.7))))
    (fp_rect (start -1.5 -3.81) (end 1.5 5.08) (layer "F.Fab") (stroke (width 0.1) (type default)))
    (pad "1" thru_hole rect   (at 0 -3.81) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 4 "VBUS"))
    (pad "2" thru_hole circle (at 0 -1.27) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 5 "CC1_5V1K"))
    (pad "3" thru_hole circle (at 0  1.27) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 6 "CC2_5V1K"))
    (pad "4" thru_hole circle (at 0  3.81) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 3 "GND"))
  )
  ;; Strain relief holes
  (pad "" np_thru_hole oval (at 10 33) (size 3.0 3.0) (drill 3.0) (layers "*.Cu" "*.Mask"))
  (pad "" np_thru_hole oval (at 10 47) (size 3.0 3.0) (drill 3.0) (layers "*.Cu" "*.Mask"))

  ;; CC pull-downs R8/R9
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 16 40)
    (reference "R8") (value "5.1k")
    (fp_text reference "R8" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "CC1_5V1K"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND")))
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 16 43)
    (reference "R9") (value "5.1k")
    (fp_text reference "R9" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "CC2_5V1K"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND")))

  ;; ============================================================
  ;; U3 — AMS1117-3.3 LDO — SOT-223, near J1
  ;; ============================================================
  (footprint "Package_TO_SOT_SMD:SOT-223-3_TabPin2" (layer "F.Cu") (at 22 40)
    (reference "U3") (value "AMS1117-3.3")
    (fp_text reference "U3" (at 0 -3.5) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "AMS1117-3.3" (at 0 3.5) (layer "F.Fab") (effects (font (size 0.8 0.8))))
    (pad "1" smd rect (at -2.3 1.5) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "2" smd rect (at 0   1.5) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "2" smd rect (at 0  -1.5) (size 3.6 2.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "3" smd rect (at 2.3  1.5) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "+5V")))

  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 16 36)
    (reference "C8") (value "10uF")
    (fp_text reference "C8" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "+5V"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND")))
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 28 40)
    (reference "C9") (value "10uF")
    (fp_text reference "C9" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND")))

  ;; ============================================================
  ;; MOD1 — GM65 QR DECODER MODULE — THT 8-pin header
  ;; Left side of board, lens faces LEFT through enclosure window
  ;; Module body ~30x17mm, connector at right edge of module
  ;; Header at x=8, module extends left toward board edge
  ;; ============================================================
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x08_P2.54mm_Vertical" (layer "F.Cu") (at 8 22)
    (reference "MOD1") (value "GM65-S_QR_Decoder")
    (fp_text reference "MOD1" (at 0 -12) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "GM65-S" (at 0 12) (layer "F.Fab") (effects (font (size 0.8 0.8))))
    ;; Module outline on Fab layer (30x17mm body, lens side faces left/board edge)
    (fp_rect (start -18 -8.5) (end 8 8.5) (layer "F.Fab") (stroke (width 0.15) (type default)))
    ;; Lens window annotation — centered on module body, near left edge
    (fp_circle (center -12 0) (end -9 0) (layer "F.Fab") (stroke (width 0.2) (type default)))
    (fp_text user "LENS" (at -12 3) (layer "F.Fab") (effects (font (size 0.7 0.7)) (justify center)))
    (fp_text user "→ ENCLOSURE WINDOW" (at -12 -3) (layer "F.Fab") (effects (font (size 0.6 0.6)) (justify center)))
    ;; 8-pin header — 2.54mm pitch
    (pad "1" thru_hole rect   (at 0  8.89) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 2 "+3.3V"))
    (pad "2" thru_hole circle (at 0  6.35) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 3 "GND"))
    (pad "3" thru_hole circle (at 0  3.81) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 10 "UART_RX"))
    (pad "4" thru_hole circle (at 0  1.27) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 9 "UART_TX"))
    (pad "5" thru_hole circle (at 0 -1.27) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 11 "GM65_TRIG"))
    (pad "6" thru_hole circle (at 0 -3.81) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "7" thru_hole circle (at 0 -6.35) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
    (pad "8" thru_hole circle (at 0 -8.89) (size 2.54 2.54) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 ""))
  )

  ;; ============================================================
  ;; U1 — STM32F072CBT6 — LQFP-48 — center-right of board
  ;; ============================================================
  (footprint "Package_QFP:LQFP-48_7x7mm_P0.5mm" (layer "F.Cu") (at 48 27)
    (reference "U1") (value "STM32F072CBT6")
    (fp_text reference "U1" (at 0 -6.5) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "STM32F072CBT6" (at 0 6.5) (layer "F.Fab") (effects (font (size 0.7 0.7))))
    (fp_rect (start -3.5 -3.5) (end 3.5 3.5) (layer "F.Fab") (stroke (width 0.1) (type default)))
    (fp_circle (center -3.5 -3.5) (end -3.0 -3.5) (layer "F.Fab") (stroke (width 0.15) (type default)))
    ;; Bottom side pins 1-12
    (pad "1"  smd rect (at -2.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "2"  smd rect (at -2.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "3"  smd rect (at -1.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "4"  smd rect (at -1.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "5"  smd rect (at -0.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "6"  smd rect (at -0.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "7"  smd rect (at  0.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 25 "NRST"))
    (pad "8"  smd rect (at  0.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "9"  smd rect (at  1.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "10" smd rect (at  1.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 18 "BTN_PA0"))
    (pad "11" smd rect (at  2.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 19 "LED_PWR_PA1"))
    (pad "12" smd rect (at  2.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 20 "LED_ARMED_PA2"))
    ;; Right side pins 13-24
    (pad "13" smd rect (at 4.75  2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 21 "LED_SIGNED_PA3"))
    (pad "14" smd rect (at 4.75  2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 14 "TFT_CS"))
    (pad "15" smd rect (at 4.75  1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "SPI_SCK"))
    (pad "16" smd rect (at 4.75  1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 22 "LED_ERROR_PA6"))
    (pad "17" smd rect (at 4.75  0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 13 "SPI_MOSI"))
    (pad "18" smd rect (at 4.75  0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "19" smd rect (at 4.75 -0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "20" smd rect (at 4.75 -0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "21" smd rect (at 4.75 -1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "TFT_BL"))
    (pad "22" smd rect (at 4.75 -1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "23" smd rect (at 4.75 -2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "24" smd rect (at 4.75 -2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    ;; Top side pins 25-36
    (pad "25" smd rect (at  2.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "26" smd rect (at  2.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "TFT_DC"))
    (pad "27" smd rect (at  1.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "TFT_RST"))
    (pad "28" smd rect (at  1.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "29" smd rect (at  0.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 11 "GM65_TRIG"))
    (pad "30" smd rect (at  0.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 9 "UART_TX"))
    (pad "31" smd rect (at -0.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "UART_RX"))
    (pad "32" smd rect (at -0.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "33" smd rect (at -1.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "34" smd rect (at -1.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 23 "SWDIO"))
    (pad "35" smd rect (at -2.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "36" smd rect (at -2.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    ;; Left side pins 37-48
    (pad "37" smd rect (at -4.75 -2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 24 "SWCLK"))
    (pad "38" smd rect (at -4.75 -2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "39" smd rect (at -4.75 -1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 27 "ATEC_ALERT"))
    (pad "40" smd rect (at -4.75 -1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "41" smd rect (at -4.75 -0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "42" smd rect (at -4.75 -0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 7 "I2C_SCL"))
    (pad "43" smd rect (at -4.75  0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "I2C_SDA"))
    (pad "44" smd rect (at -4.75  0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 26 "BOOT0"))
    (pad "45" smd rect (at -4.75  1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "46" smd rect (at -4.75  1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "47" smd rect (at -4.75  2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "48" smd rect (at -4.75  2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
  )

  ;; VDD decoupling — right next to U1
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 42 27)

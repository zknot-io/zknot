  ;; ============================================================
  ;; GND POUR — both layers + stitching vias
  ;; ============================================================
  (zone (net 3) (net_name "GND") (layer "F.Cu") (tstamp "zone-gnd-f-air")
    (hatch style "edge" pitch 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.25)

  ;; ============================================================
  ;; COPPER ZONES — GND pour both layers, stitching vias
  ;; ============================================================
  (zone (net 3) (net_name "GND") (layer "F.Cu") (tstamp "zone-gnd-f")
    (hatch style "edge" pitch 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.25)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts (xy 0.5 0.5) (xy 59.5 0.5) (xy 59.5 39.5) (xy 0.5 39.5)))
  )
  (zone (net 3) (net_name "GND") (layer "B.Cu") (tstamp "zone-gnd-b")
    (hatch style "edge" pitch 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.25)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts (xy 0.5 0.5) (xy 59.5 0.5) (xy 59.5 39.5) (xy 0.5 39.5)))
  )

  ;; GND stitching vias — spread across board
  (via (at 15 20) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 25 30) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 45 10) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 55 25) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 35 35) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 3))
  (via (at 20 35) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 3))

  ;; ============================================================
  ;; KEY TRACES — critical signal routes
  ;; USB differential pair — 90Ω controlled impedance, matched length
  ;; ============================================================
  (segment (start 30.25 17.25) (end 22 17.25) (width 0.2) (layer "F.Cu") (net 4))
  (segment (start 22 17.25) (end 8 18.73) (width 0.2) (layer "F.Cu") (net 4))
  (segment (start 29.75 17.25) (end 21.5 17.25) (width 0.2) (layer "F.Cu") (net 5))
  (segment (start 21.5 17.25) (end 8 19.27) (width 0.2) (layer "F.Cu") (net 5))

  ;; I2C bus — U1 pins 42,43 to U2 pins 7,5
  (segment (start 30.25 21.75) (end 44 18) (width 0.25) (layer "F.Cu") (net 6))
  (segment (start 44 18) (end 47 15.635) (width 0.25) (layer "F.Cu") (net 6))
  (segment (start 30.25 22.25) (end 44 21) (width 0.25) (layer "F.Cu") (net 7))
  (segment (start 44 21) (end 47 16.905) (width 0.25) (layer "F.Cu") (net 7))

  ;; SWD — U1 pins 34,37 to J2
  (segment (start 30.25 17.25) (end 54 3.2) (width 0.25) (layer "F.Cu") (net 8))
  (segment (start 30.25 19.25) (end 54 8.8) (width 0.25) (layer "F.Cu") (net 9))

  ;; ============================================================
  ;; SILKSCREEN — F.SilkS FRONT
  ;; Design intent: instrument panel aesthetic
  ;; Every zone labeled by function, not just designator
  ;; Doctrine on board — physics enforces, math proves, you verify
  ;; ============================================================

  ;; --- TOP BAND — Product identity ---
  (gr_text "ZKNOT" (at 5 1.5) (layer "F.SilkS") (effects (font (size 1.4 1.4) (bold yes))))
  (gr_text "ZKKey Connect" (at 22 1.5) (layer "F.SilkS") (effects (font (size 1.2 1.2) (bold yes))))
  (gr_text "REV A" (at 46 1.5) (layer "F.SilkS") (effects (font (size 0.8 0.8))))
  (gr_text "PAT. PEND." (at 55 1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7)) (justify right)))
  ;; Thin rule under top band
  (gr_line (start 1 2.8) (end 59 2.8) (layer "F.SilkS") (stroke (width 0.1) (type default)))

  ;; --- USB INPUT ZONE — J1 pigtail, left side ---
  ;; Zone box around J1 (which is at x=8, y=20, holes from y=13.65 to y=26.35)
  (gr_rect (start 2.5 8.5) (end 14.5 31) (layer "F.SilkS") (stroke (width 0.12) (type default)))
  (gr_text "PHYSICAL" (at 8.5 9.5) (layer "F.SilkS") (effects (font (size 0.65 0.65) (bold yes)) (justify center)))
  (gr_text "INTERFACE" (at 8.5 10.5) (layer "F.SilkS") (effects (font (size 0.65 0.65) (bold yes)) (justify center)))
  (gr_text "USB-C" (at 8.5 11.5) (layer "F.SilkS") (effects (font (size 0.6 0.6)) (justify center)))
  ;; Wire labels — aligned to hole positions
  (gr_text "VBUS" (at 12.2 13.65) (layer "F.SilkS") (effects (font (size 0.6 0.6))))
  (gr_text "D-" (at 12.2 16.19) (layer "F.SilkS") (effects (font (size 0.6 0.6))))
  (gr_text "D+" (at 12.2 18.73) (layer "F.SilkS") (effects (font (size 0.6 0.6))))
  (gr_text "CC1" (at 12.2 21.27) (layer "F.SilkS") (effects (font (size 0.6 0.6))))
  (gr_text "CC2" (at 12.2 23.81) (layer "F.SilkS") (effects (font (size 0.6 0.6))))
  (gr_text "GND" (at 12.2 26.35) (layer "F.SilkS") (effects (font (size 0.6 0.6))))
  ;; Solder instruction — bottom of zone
  (gr_text "WIRE ENTRY" (at 8.5 28.0) (layer "F.SilkS") (effects (font (size 0.55 0.55)) (justify center)))
  (gr_text "SOLDER BOTTOM" (at 8.5 29.0) (layer "F.SilkS") (effects (font (size 0.55 0.55)) (justify center)))
  ;; Pin 1 arrow
  (gr_text "1>" (at 2.8 13.65) (layer "F.SilkS") (effects (font (size 0.55 0.55))))

  ;; --- LDO ZONE — U3 ---
  (gr_text "3.3V POWER" (at 20 7.5) (layer "F.SilkS") (effects (font (size 0.6 0.6)) (justify center)))

  ;; --- MCU ZONE — U1, centered at 35,22 ---
  ;; Label above U1 (U1 top edge ~y=17)
  (gr_text "CONTROLLER" (at 35 16.0) (layer "F.SilkS") (effects (font (size 0.65 0.65)) (justify center)))
  (gr_text "STM32F072" (at 35 17.0) (layer "F.SilkS") (effects (font (size 0.6 0.6)) (justify center)))

  ;; --- SECURE ELEMENT ZONE — U2, centered at 50,15 ---
  ;; Box around U2 (SOIC-8 body ~4.9x3.9mm, centered 50,15)
  (gr_rect (start 43 10.5) (end 58 21.5) (layer "F.SilkS") (stroke (width 0.12) (type default)))
  (gr_text "SECURE ELEMENT" (at 50.5 11.5) (layer "F.SilkS") (effects (font (size 0.65 0.65) (bold yes)) (justify center)))
  (gr_text "ATECC608A" (at 50.5 12.5) (layer "F.SilkS") (effects (font (size 0.6 0.6)) (justify center)))
  ;; The moat — true, verifiable, on record
  (gr_text "PRIVATE KEY" (at 50.5 19.5) (layer "F.SilkS") (effects (font (size 0.6 0.6) (bold yes)) (justify center)))
  (gr_text "NEVER LEAVES" (at 50.5 20.5) (layer "F.SilkS") (effects (font (size 0.6 0.6) (bold yes)) (justify center)))

  ;; --- SWD DEBUG ZONE — J2 at 54,5 ---
  (gr_rect (start 49.5 1.5) (end 59.5 12.5) (layer "F.SilkS") (stroke (width 0.1) (type default)))
  (gr_text "DEBUG" (at 54.5 2.8) (layer "F.SilkS") (effects (font (size 0.6 0.6) (bold yes)) (justify center)))
  (gr_text "SWD" (at 54.5 3.8) (layer "F.SilkS") (effects (font (size 0.6 0.6)) (justify center)))
  ;; Pin labels — J2 pads at y=3.2(3V3) 5.7(DIO) 8.2(GND) 10.7(CLK) offset from J2 center 54,5
  (gr_text "3V3" (at 56.5 3.19) (layer "F.SilkS") (effects (font (size 0.55 0.55))))
  (gr_text "DIO" (at 56.5 5.73) (layer "F.SilkS") (effects (font (size 0.55 0.55))))
  (gr_text "GND" (at 56.5 8.27) (layer "F.SilkS") (effects (font (size 0.55 0.55))))
  (gr_text "CLK" (at 56.5 10.81) (layer "F.SilkS") (effects (font (size 0.55 0.55))))

  ;; --- BOOT0 JUMPER — J3 at 48,5 ---
  (gr_text "BOOT0" (at 48 2.5) (layer "F.SilkS") (effects (font (size 0.6 0.6) (bold yes)) (justify center)))
  (gr_text "SHORT" (at 45.5 4.5) (layer "F.SilkS") (effects (font (size 0.55 0.55))))
  (gr_text "=DFU" (at 45.5 5.5) (layer "F.SilkS") (effects (font (size 0.55 0.55))))
  (gr_text "OPEN" (at 45.5 7.0) (layer "F.SilkS") (effects (font (size 0.55 0.55))))
  (gr_text "=RUN" (at 45.5 8.0) (layer "F.SilkS") (effects (font (size 0.55 0.55))))

  ;; --- SIGN BUTTON — SW1 at 30,35 ---
  ;; Large, unmistakable — this is the UX
  (gr_text "SIGN" (at 30 31.5) (layer "F.SilkS") (effects (font (size 1.8 1.8) (bold yes)) (justify center)))
  (gr_text "one press  ·  one signature" (at 30 33.2) (layer "F.SilkS") (effects (font (size 0.65 0.65)) (justify center)))

  ;; --- LED ROW — D1-D4 at x=42,46,50,54 y=35 ---
  ;; Functional labels above each LED (y~32, above resistors at y=30)
  (gr_text "PWR" (at 42 27.5) (layer "F.SilkS") (effects (font (size 0.65 0.65)) (justify center)))
  (gr_text "ARMED" (at 46 27.5) (layer "F.SilkS") (effects (font (size 0.65 0.65)) (justify center)))
  (gr_text "SIGNED" (at 50 27.5) (layer "F.SilkS") (effects (font (size 0.65 0.65)) (justify center)))
  (gr_text "ERROR" (at 54 27.5) (layer "F.SilkS") (effects (font (size 0.65 0.65)) (justify center)))
  ;; LED color dots below labels (reminder during assembly)
  (gr_text "GRN" (at 42 28.5) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center)))
  (gr_text "YLW" (at 46 28.5) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center)))
  (gr_text "BLU" (at 50 28.5) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center)))
  (gr_text "RED" (at 54 28.5) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center)))
  ;; LED polarity reminder — flat=K=GND, at pad 1 (square, left)
  (gr_text "K+" (at 40.5 35.0) (layer "F.SilkS") (effects (font (size 0.5 0.5))))
  (gr_text "K+" (at 44.5 35.0) (layer "F.SilkS") (effects (font (size 0.5 0.5))))
  (gr_text "K+" (at 48.5 35.0) (layer "F.SilkS") (effects (font (size 0.5 0.5))))
  (gr_text "K+" (at 52.5 35.0) (layer "F.SilkS") (effects (font (size 0.5 0.5))))

  ;; --- LEFT EDGE — Test point column labels ---
  ;; Rotated 90° vertical strip, TP1-TP7 at x=0, y=10–28
  (gr_text "TEST POINTS" (at 1.2 19) (layer "F.SilkS") (effects (font (size 0.55 0.55)) (justify center) (rotate 90)))
  (gr_text "GND" (at 2.2 10) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))
  (gr_text "3V3" (at 2.2 13) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))
  (gr_text "5V"  (at 2.2 16) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))
  (gr_text "D-"  (at 2.2 19) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))
  (gr_text "D+"  (at 2.2 22) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))
  (gr_text "SCL" (at 2.2 25) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))
  (gr_text "SDA" (at 2.2 28) (layer "F.SilkS") (effects (font (size 0.5 0.5)) (justify center) (rotate 90)))

  ;; --- BOTTOM BAND — Serial, URLs, doctrine ---
  (gr_line (start 1 36.5) (end 59 36.5) (layer "F.SilkS") (stroke (width 0.1) (type default)))
  (gr_text "SN:" (at 2 37.3) (layer "F.SilkS") (effects (font (size 0.7 0.7) (bold yes))))
  (gr_text "____________________" (at 8 37.3) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
  (gr_text "verifyknot.io" (at 50 37.3) (layer "F.SilkS") (effects (font (size 0.7 0.7)) (justify right)))
  ;; Doctrine line — the whole thesis in one sentence
  (gr_text "Physics enforces.  Math proves.  You verify." (at 30 38.7) (layer "F.SilkS") (effects (font (size 0.7 0.7) (italic yes)) (justify center)))

  ;; ============================================================
  ;; SILKSCREEN — B.SilkS BACK (readable when board is flipped)
  ;; ============================================================

  ;; Back identity — board stands alone, no roadmap reference
  (gr_text "ZKKey Connect" (at 30 2.5) (layer "B.SilkS") (effects (font (size 1.1 1.1) (bold yes)) (justify center) (mirror yes)))
  (gr_text "ZKNOT, INC." (at 30 4.5) (layer "B.SilkS") (effects (font (size 0.8 0.8)) (justify center) (mirror yes)))
  (gr_text "zknot.io" (at 30 6.0) (layer "B.SilkS") (effects (font (size 0.8 0.8)) (justify center) (mirror yes)))

  ;; Patent and legal
  (gr_text "Patent Pending — App# 63/960,933" (at 30 9.0) (layer "B.SilkS") (effects (font (size 0.65 0.65)) (justify center) (mirror yes)))
  (gr_text "ZKNOT, INC.  EIN 36-5165991" (at 30 10.5) (layer "B.SilkS") (effects (font (size 0.65 0.65)) (justify center) (mirror yes)))
  (gr_text "Veteran-Owned  SDVOSB" (at 30 12.0) (layer "B.SilkS") (effects (font (size 0.65 0.65)) (justify center) (mirror yes)))

  ;; Back serial block — for label application / data room photos
  (gr_text "SN:" (at 10 20) (layer "B.SilkS") (effects (font (size 0.8 0.8) (bold yes)) (mirror yes)))
  (gr_text "____________________" (at 20 20) (layer "B.SilkS") (effects (font (size 0.8 0.8)) (mirror yes)))

  ;; Back doctrine — for when someone flips the board and asks "what is this"
  (gr_text "Cryptographic human-presence attestation." (at 30 35.0) (layer "B.SilkS") (effects (font (size 0.65 0.65)) (justify center) (mirror yes)))
  (gr_text "When physics is policy, trust is optional." (at 30 36.5) (layer "B.SilkS") (effects (font (size 0.65 0.65) (italic yes)) (justify center) (mirror yes)))

  ;; Assembly zone boundary (F.Fab)
  (gr_rect (start 5 5) (end 58 38) (layer "F.Fab") (stroke (width 0.1) (type default)))

  ;; Courtyard
  (gr_rect (start 0.25 0.25) (end 59.75 39.75) (layer "F.CrtYd") (stroke (width 0.05) (type default)))

  ;; Assembly zone boundary (F.Fab)
  (gr_rect (start 5 5) (end 58 38) (layer "F.Fab") (stroke (width 0.1) (type default)))


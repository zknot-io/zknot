(kicad_pcb
  (version 20231120)
  (generator "pcbnew")
  (generator_version "7.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "ZKKey Connect RevA")
    (date "2026-04-16")
    (rev "A")
    (company "ZKNOT, INC.")
    (comment 1 "STM32F072CBT6 + ATECC608A USB Signing Device")
    (comment 2 "PAT-001 — Provisional filed 2026-01-15")
  )

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )

  (setup
    (pad_to_mask_clearance 0.1)
    (smd_solver_allow_incompatible_copper_layers no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk yes)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  (net 0 "")
  (net 1 "+5V")
  (net 2 "+3.3V")
  (net 3 "GND")
  (net 4 "USB_DM")
  (net 5 "USB_DP")
  (net 6 "I2C_SCL")
  (net 7 "I2C_SDA")
  (net 8 "SWDIO")
  (net 9 "SWCLK")
  (net 10 "NRST")
  (net 11 "BOOT0")
  (net 12 "BTN_PA0")
  (net 13 "LED_PWR_PA1")
  (net 14 "LED_ARMED_PA2")
  (net 15 "LED_SIGNED_PA3")
  (net 16 "LED_ERROR_PA4")
  (net 17 "ATEC_ALERT_PA5")
  (net 18 "VBUS")
  (net 19 "CC1_5V1K")
  (net 20 "CC2_5V1K")

  ;; ============================================================
  ;; BOARD OUTLINE — 60mm x 40mm
  ;; ============================================================
  (gr_rect (start 0 0) (end 60 40) (layer "Edge.Cuts") (stroke (width 0.05) (type default)))

  ;; ============================================================
  ;; MOUNTING HOLES — M3, 3.2mm drill, 4 corners
  ;; ============================================================
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 3.5 3.5)
    (reference "H1") (value "MountingHole_M3")
    (fp_circle (center 0 0) (end 1.6 0) (layer "F.Fab") (stroke (width 0.15) (type default)))
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 56.5 3.5)
    (reference "H2") (value "MountingHole_M3")
    (fp_circle (center 0 0) (end 1.6 0) (layer "F.Fab") (stroke (width 0.15) (type default)))
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 3.5 36.5)
    (reference "H3") (value "MountingHole_M3")
    (fp_circle (center 0 0) (end 1.6 0) (layer "F.Fab") (stroke (width 0.15) (type default)))
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 56.5 36.5)
    (reference "H4") (value "MountingHole_M3")
    (fp_circle (center 0 0) (end 1.6 0) (layer "F.Fab") (stroke (width 0.15) (type default)))
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask"))
  )

  ;; ============================================================
  ;; EDGE TEST POINTS — 1mm pads on board edge (standard: GND, 3V3, 5V, DM, DP, SCL, SDA)
  ;; ============================================================
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 10)
    (reference "TP1") (value "GND_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 3 "GND"))
  )
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 13)
    (reference "TP2") (value "3V3_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 2 "+3.3V"))
  )
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 16)
    (reference "TP3") (value "5V_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 1 "+5V"))
  )
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 19)
    (reference "TP4") (value "USB_DM_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 4 "USB_DM"))
  )
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 22)
    (reference "TP5") (value "USB_DP_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 5 "USB_DP"))
  )
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 25)
    (reference "TP6") (value "I2C_SCL_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 6 "I2C_SCL"))
  )
  (footprint "TestPoint:TestPoint_Pad_D1.0mm" (layer "F.Cu") (at 0 28)
    (reference "TP7") (value "I2C_SDA_EDGE")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 7 "I2C_SDA"))
  )

  ;; ============================================================
  ;; J1 — USB-C MALE PIGTAIL — THT wire entry
  ;; 6 holes, 2.54mm pitch, left edge, wires enter from board bottom
  ;; VBUS, DM, DP, CC1, CC2, GND
  ;; ============================================================
  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x06_P2.54mm_Vertical" (layer "F.Cu") (at 8 20)
    (reference "J1") (value "USB-C_Male_Pigtail")
    (fp_text reference "J1" (at 0 -9) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "USB-C_Male_Pigtail" (at 0 10) (layer "F.Fab") (effects (font (size 0.8 0.8))))
    (fp_rect (start -1.5 -8.9) (end 1.5 7.5) (layer "F.Fab") (stroke (width 0.1) (type default)))
    ;; Wire-through holes 1.5mm drill — large enough for 22AWG flood solder
    (pad "1" thru_hole circle (at 0 -6.35) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 18 "VBUS"))
    (pad "2" thru_hole circle (at 0 -3.81) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 4 "USB_DM"))
    (pad "3" thru_hole circle (at 0 -1.27) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 5 "USB_DP"))
    (pad "4" thru_hole circle (at 0 1.27) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 19 "CC1_5V1K"))
    (pad "5" thru_hole circle (at 0 3.81) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 20 "CC2_5V1K"))
    (pad "6" thru_hole circle (at 0 6.35) (size 3.2 3.2) (drill 1.5) (layers "*.Cu" "*.Mask") (net 3 "GND"))
  )

  ;; Strain relief hole pair — 3mm drill, 10mm apart, above/below pigtail entry
  (pad "" np_thru_hole oval (at 8 10) (size 3.0 3.0) (drill 3.0) (layers "*.Cu" "*.Mask"))
  (pad "" np_thru_hole oval (at 8 30) (size 3.0 3.0) (drill 3.0) (layers "*.Cu" "*.Mask"))

  ;; Silk labels for pigtail wires
  (gr_text "VBUS" (at 11 13.65) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
  (gr_text "DM" (at 11 16.19) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
  (gr_text "DP" (at 11 18.73) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
  (gr_text "CC1" (at 11 21.27) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
  (gr_text "CC2" (at 11 23.81) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
  (gr_text "GND" (at 11 26.35) (layer "F.SilkS") (effects (font (size 0.7 0.7))))

  ;; ============================================================
  ;; U3 — AMS1117-3.3 LDO — SOT-223, near USB pigtail
  ;; ============================================================
  (footprint "Package_TO_SOT_SMD:SOT-223-3_TabPin2" (layer "F.Cu") (at 20 10)
    (reference "U3") (value "AMS1117-3.3")
    (fp_text reference "U3" (at 0 -3.5) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "AMS1117-3.3" (at 0 3.5) (layer "F.Fab") (effects (font (size 0.8 0.8))))
    ;; GND pin 1
    (pad "1" smd rect (at -2.3 1.5) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    ;; OUT pin 2 + tab
    (pad "2" smd rect (at 0 1.5) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "2" smd rect (at 0 -1.5) (size 3.6 2.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    ;; IN pin 3
    (pad "3" smd rect (at 2.3 1.5) (size 1.5 2.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "+5V"))
  )

  ;; LDO decoupling — C8 input, C9 output
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 16 10)
    (reference "C8") (value "10uF")
    (fp_text reference "C8" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "+5V"))
    (pad "2" smd rect (at 1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
  )
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 24 10)
    (reference "C9") (value "10uF")
    (fp_text reference "C9" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "2" smd rect (at 1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
  )

  ;; CC pulldown resistors R8, R9 — 5.1k, near J1
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 8 34)
    (reference "R8") (value "5.1k")
    (fp_text reference "R8" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 19 "CC1_5V1K"))
    (pad "2" smd rect (at 1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
  )
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 8 37)
    (reference "R9") (value "5.1k")
    (fp_text reference "R9" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 20 "CC2_5V1K"))
    (pad "2" smd rect (at 1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
  )

  ;; ============================================================
  ;; U1 — STM32F072CBT6 — LQFP-48, 7x7mm, 0.5mm pitch — center of board
  ;; ============================================================
  (footprint "Package_QFP:LQFP-48_7x7mm_P0.5mm" (layer "F.Cu") (at 35 22)
    (reference "U1") (value "STM32F072CBT6")
    (fp_text reference "U1" (at 0 -6) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "STM32F072CBT6" (at 0 6) (layer "F.Fab") (effects (font (size 0.7 0.7))))
    (fp_rect (start -3.5 -3.5) (end 3.5 3.5) (layer "F.Fab") (stroke (width 0.1) (type default)))
    ;; Pin 1 marker
    (fp_circle (center -3.5 -3.5) (end -3.0 -3.5) (layer "F.Fab") (stroke (width 0.15) (type default)))
    ;; LQFP-48 pads — 12 per side, 0.5mm pitch, pad 1.5x0.3mm
    ;; Bottom side: pins 1-12 (left to right)
    (pad "1"  smd rect (at -2.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "2"  smd rect (at -2.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "3"  smd rect (at -1.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "4"  smd rect (at -1.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "5"  smd rect (at -0.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "ATEC_ALERT_PA5"))
    (pad "6"  smd rect (at -0.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "ATEC_ALERT_PA5"))
    (pad "7"  smd rect (at  0.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "NRST"))
    (pad "8"  smd rect (at  0.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "9"  smd rect (at  1.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    (pad "10" smd rect (at  1.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "BTN_PA0"))
    (pad "11" smd rect (at  2.25 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 13 "LED_PWR_PA1"))
    (pad "12" smd rect (at  2.75 4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 14 "LED_ARMED_PA2"))
    ;; Right side: pins 13-24 (top to bottom)
    (pad "13" smd rect (at 4.75 2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "LED_SIGNED_PA3"))
    (pad "14" smd rect (at 4.75 2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "LED_ERROR_PA4"))
    (pad "15" smd rect (at 4.75 1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "ATEC_ALERT_PA5"))
    (pad "16" smd rect (at 4.75 1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "17" smd rect (at 4.75 0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "18" smd rect (at 4.75 0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "19" smd rect (at 4.75 -0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "20" smd rect (at 4.75 -0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "21" smd rect (at 4.75 -1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "22" smd rect (at 4.75 -1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "23" smd rect (at 4.75 -2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "24" smd rect (at 4.75 -2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
    ;; Top side: pins 25-36 (right to left)
    (pad "25" smd rect (at  2.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "26" smd rect (at  2.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "27" smd rect (at  1.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "28" smd rect (at  1.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "29" smd rect (at  0.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "30" smd rect (at  0.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "31" smd rect (at -0.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "32" smd rect (at -0.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "USB_DM"))
    (pad "33" smd rect (at -1.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "USB_DP"))
    (pad "34" smd rect (at -1.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "SWDIO"))
    (pad "35" smd rect (at -2.25 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "36" smd rect (at -2.75 -4.75) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    ;; Left side: pins 37-48 (bottom to top)
    (pad "37" smd rect (at -4.75 -2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 9 "SWCLK"))
    (pad "38" smd rect (at -4.75 -2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "39" smd rect (at -4.75 -1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "40" smd rect (at -4.75 -1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "41" smd rect (at -4.75 -0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "42" smd rect (at -4.75 -0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "I2C_SCL"))
    (pad "43" smd rect (at -4.75  0.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 7 "I2C_SDA"))
    (pad "44" smd rect (at -4.75  0.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 11 "BOOT0"))
    (pad "45" smd rect (at -4.75  1.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "46" smd rect (at -4.75  1.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "47" smd rect (at -4.75  2.25) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "GND"))
    (pad "48" smd rect (at -4.75  2.75) (size 0.3 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))
  )

  ;; VDD decoupling caps — placed right next to U1 power pins on F.Cu
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 30 22)
    (reference "C3") (value "100nF")
    (fp_text reference "C3" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "+3.3V"))

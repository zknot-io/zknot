(kicad_pcb
  (version 20231120)
  (generator "pcbnew")
  (generator_version "7.0")
  (general (thickness 1.6) (legacy_teardrops no))
  (paper "A4")
  (title_block
    (title "TrustMeter RevA")
    (date "2026-04-16")
    (rev "A")
    (company "ZKNOT, INC.")
    (comment 1 "USB Electrical Behavior Measurement & Attestation")
    (comment 2 "PAT-015 App# 64/007,931 | PAT-016 App# 64/007,934")
  )

  (layers
    (0  "F.Cu"     signal)
    (31 "B.Cu"     signal)
    (34 "B.Paste"  user)
    (35 "F.Paste"  user)
    (36 "B.SilkS"  user "B.Silkscreen")
    (37 "F.SilkS"  user "F.Silkscreen")
    (38 "B.Mask"   user)
    (39 "F.Mask"   user)
    (40 "Dwgs.User" user "User.Drawings")
    (44 "Edge.Cuts" user)
    (46 "B.CrtYd"  user "B.Courtyard")
    (47 "F.CrtYd"  user "F.Courtyard")
    (48 "B.Fab"    user "B.Fabrication")
    (49 "F.Fab"    user "F.Fabrication")
  )

  (setup
    (pad_to_mask_clearance 0.1)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (subtractmaskfromsilk yes)
      (outputformat 1)
      (outputdirectory "gerbers/")
    )
  )

  ;; ── Nets ────────────────────────────────────────────────────────────────────
  (net 0  "")
  (net 1  "+3.3V")
  (net 2  "GND")
  (net 3  "+5V_VBUS_UP")
  (net 4  "VBUS_SHUNT_HI")
  (net 5  "VBUS_SHUNT_LO")
  (net 6  "VBUS_DOWN")
  (net 7  "DM_UP")
  (net 8  "DP_UP")
  (net 9  "CC1_UP")
  (net 10 "CC2_UP")
  (net 11 "DM_DOWN")
  (net 12 "DP_DOWN")
  (net 13 "CC1_DOWN")
  (net 14 "CC2_DOWN")
  (net 15 "ADC_VBUS")
  (net 16 "ADC_DM")
  (net 17 "ADC_DP")
  (net 18 "ADC_CC1")
  (net 19 "ADC_CC2")
  (net 20 "I2C_SCL")
  (net 21 "I2C_SDA")
  (net 22 "INA_ALERT")
  (net 23 "SWDIO")
  (net 24 "SWCLK")
  (net 25 "NRST")
  (net 26 "BOOT0")
  (net 27 "SPI_SCK")
  (net 28 "SPI_MOSI")
  (net 29 "OLED_CS")
  (net 30 "OLED_DC")
  (net 31 "OLED_RST")
  (net 32 "LED_OK")
  (net 33 "LED_FAULT")
  (net 34 "BTN_MEAS")
  (net 35 "ATEC_ALERT")
  (net 36 "USB_CDC_DM")
  (net 37 "USB_CDC_DP")

  ;; ── Board outline: 80 × 50mm ────────────────────────────────────────────────
  (gr_rect (start 0 0) (end 80 50) (layer "Edge.Cuts") (stroke (width 0.05) (type default)))

  ;; ── Mounting holes: M3, 4 corners ───────────────────────────────────────────
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 3.5 3.5)
    (reference "H1") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 76.5 3.5)
    (reference "H2") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 3.5 46.5)
    (reference "H3") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 76.5 46.5)
    (reference "H4") (value "M3")
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask")))

  ;; ── Edge test points: left edge ─────────────────────────────────────────────
  ;; VBUS_UP, GND, 3V3, SHUNT_HI, SHUNT_LO, DM, DP, CC1, CC2, SCL, SDA
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 10)
    (reference "TP1")  (value "VBUS_UP")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 3 "+5V_VBUS_UP")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 13)
    (reference "TP2")  (value "GND")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 2 "GND")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 16)
    (reference "TP3")  (value "3V3")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 1 "+3.3V")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 19)
    (reference "TP4")  (value "SHUNT_HI")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 4 "VBUS_SHUNT_HI")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 22)
    (reference "TP5")  (value "SHUNT_LO")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 5 "VBUS_SHUNT_LO")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 25)
    (reference "TP6")  (value "DM")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 7 "DM_UP")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 28)
    (reference "TP7")  (value "DP")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 8 "DP_UP")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 31)
    (reference "TP8")  (value "CC1")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 9 "CC1_UP")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 34)
    (reference "TP9")  (value "CC2")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 10 "CC2_UP")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 37)
    (reference "TP10") (value "SCL")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 20 "I2C_SCL")))
  (footprint "TestPoint:TestPoint_Pad_D1.5mm" (layer "F.Cu") (at 0 40)
    (reference "TP11") (value "SDA")
    (pad "1" smd rect (at 0 0) (size 1.5 1.5) (layers "F.Cu" "F.Mask") (net 21 "I2C_SDA")))

  ;; ── J1 — USB-C UPSTREAM (host / power source side) ─────────────────────────
  ;; SMD, left side of board, cable enters from left
  ;; GCT USB4105-GF-A or equivalent SMD USB-C receptacle
  (footprint "Connector_USB:USB_C_Receptacle_GCT_USB4105-GF-A" (layer "F.Cu") (at 10 13)
    (reference "J1") (value "USB-C_Upstream")
    (fp_text reference "J1" (at 0 -5) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "UPSTREAM" (at 0 5) (layer "F.SilkS") (effects (font (size 0.8 0.8))))
    ;; VBUS pins A4+B4 — 2A trace to shunt
    (pad "A4"  smd rect   (at -2.5 -2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "+5V_VBUS_UP"))
    (pad "B4"  smd rect   (at  2.5 -2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "+5V_VBUS_UP"))
    (pad "A1"  smd rect   (at -2.5  2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND"))
    (pad "B1"  smd rect   (at  2.5  2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND"))
    (pad "A5"  smd rect   (at -1.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 9  "CC1_UP"))
    (pad "B5"  smd rect   (at  1.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "CC2_UP"))
    (pad "A6"  smd rect   (at -1.0 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 8  "DP_UP"))
    (pad "A7"  smd rect   (at -0.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 7  "DM_UP"))
    (pad "A8"  smd rect   (at  0.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "B8"  smd rect   (at  1.0 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "S1"  smd rect   (at  0.0  3.5) (size 6.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND"))
  )

  ;; ── J2 — USB-C DOWNSTREAM (DUT / device under test side) ───────────────────
  ;; SMD, right side of board, cable exits to DUT
  (footprint "Connector_USB:USB_C_Receptacle_GCT_USB4105-GF-A" (layer "F.Cu") (at 70 13)
    (reference "J2") (value "USB-C_Downstream_DUT")
    (fp_text reference "J2" (at 0 -5) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "DUT" (at 0 5) (layer "F.SilkS") (effects (font (size 0.8 0.8))))
    (pad "A4"  smd rect   (at -2.5 -2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "VBUS_DOWN"))
    (pad "B4"  smd rect   (at  2.5 -2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "VBUS_DOWN"))
    (pad "A1"  smd rect   (at -2.5  2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND"))
    (pad "B1"  smd rect   (at  2.5  2.5) (size 0.6 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND"))
    (pad "A5"  smd rect   (at -1.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 13 "CC1_DOWN"))
    (pad "B5"  smd rect   (at  1.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 14 "CC2_DOWN"))
    (pad "A6"  smd rect   (at -1.0 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "DP_DOWN"))
    (pad "A7"  smd rect   (at -0.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 11 "DM_DOWN"))
    (pad "A8"  smd rect   (at  0.5 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "B8"  smd rect   (at  1.0 -2.5) (size 0.35 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 0 ""))
    (pad "S1"  smd rect   (at  0.0  3.5) (size 6.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND"))
  )

  ;; ── R_SH1 — 10mΩ SHUNT — 2512 SMD — in VBUS path between J1 and J2 ────────
  ;; CRITICAL LAYOUT: place on VBUS copper path, Kelvin connections to INA228
  ;; Short, fat traces on power pins; long, thin sense traces to INA228 IN+/IN-
  (footprint "Resistor_SMD:R_2512_6332Metric" (layer "F.Cu") (at 30 10)
    (reference "R_SH1") (value "10mR_2W")
    (fp_text reference "R_SH1" (at 0 -3) (layer "F.SilkS") (effects (font (size 0.8 0.8))))
    (fp_text value "10mΩ SHUNT" (at 0 3) (layer "F.SilkS") (effects (font (size 0.8 0.8))))
    ;; 2512 pad: 3.5mm × 2.6mm, 5.4mm pitch
    (pad "1" smd rect (at -2.7 0) (size 3.5 2.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "VBUS_SHUNT_HI"))
    (pad "2" smd rect (at  2.7 0) (size 3.5 2.6) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "VBUS_SHUNT_LO"))
  )

  ;; ── U2 — INA228 — VSSOP-10 — near shunt ────────────────────────────────────
  ;; CRITICAL LAYOUT: IN+/IN- Kelvin sense traces must be short and symmetric
  ;; A0=A1=GND → I2C address 0x40. VS pin connected to VBUS_SHUNT_LO.
  (footprint "Package_SO:VSSOP-10_3x3mm_P0.5mm" (layer "F.Cu") (at 30 22)
    (reference "U2") (value "INA228AIDGST")
    (fp_text reference "U2" (at 0 -3) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "INA228" (at 0 3) (layer "F.Fab") (effects (font (size 0.7 0.7))))
    (fp_rect (start -1.5 -1.5) (end 1.5 1.5) (layer "F.Fab") (stroke (width 0.1) (type default)))
    ;; VSSOP-10: 5 pins per side, 0.5mm pitch, pad 1.5×0.3mm
    ;; Left side pins 1-5
    (pad "1"  smd rect (at -2.3  1.0) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 4  "VBUS_SHUNT_HI"))
    (pad "2"  smd rect (at -2.3  0.5) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 5  "VBUS_SHUNT_LO"))
    (pad "3"  smd rect (at -2.3  0.0) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2  "GND"))
    (pad "4"  smd rect (at -2.3 -0.5) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2  "GND"))
    (pad "5"  smd rect (at -2.3 -1.0) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2  "GND"))
    ;; Right side pins 6-10
    (pad "6"  smd rect (at  2.3 -1.0) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 5  "VBUS_SHUNT_LO"))
    (pad "7"  smd rect (at  2.3 -0.5) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 22 "INA_ALERT"))
    (pad "8"  smd rect (at  2.3  0.0) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 21 "I2C_SDA"))
    (pad "9"  smd rect (at  2.3  0.5) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 20 "I2C_SCL"))
    (pad "10" smd rect (at  2.3  1.0) (size 1.5 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 5  "VBUS_SHUNT_LO"))
  )
  ;; INA228 VS decoupling — right next to chip
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 34 19)
    (reference "C_INA1") (value "100nF")
    (fp_text reference "C_INA1" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "VBUS_SHUNT_LO"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 34 22)
    (reference "C_INA2") (value "10uF")
    (fp_text reference "C_INA2" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "VBUS_SHUNT_LO"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))

  ;; ── Voltage divider network — signal tap resistors ────────────────────────
  ;; All on F.Cu, right of center, between USB connectors and MCU ADC inputs
  ;; VBUS divider: 100kΩ top (R1) + 10kΩ bottom (R2), midpoint → ADC_VBUS
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 10)
    (reference "R1") (value "100k")
    (fp_text reference "R1" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "VBUS_SHUNT_LO"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "ADC_VBUS")))
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 13)
    (reference "R2") (value "10k")
    (fp_text reference "R2" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "ADC_VBUS"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))
  ;; VBUS ADC filter cap
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 49 11.5)
    (reference "C_ADC1") (value "10nF")
    (fp_text reference "C_ADC1" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "ADC_VBUS"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))

  ;; DM divider: 100kΩ + 100kΩ
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 17)
    (reference "R3") (value "100k")
    (fp_text reference "R3" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 7  "DM_UP"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "ADC_DM")))
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 20)
    (reference "R4") (value "100k")
    (fp_text reference "R4" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "ADC_DM"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 49 18.5)
    (reference "C_ADC2") (value "10nF")
    (fp_text reference "C_ADC2" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "ADC_DM"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))

  ;; DP divider
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 24)
    (reference "R5") (value "100k")
    (fp_text reference "R5" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 8  "DP_UP"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "ADC_DP")))
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 27)
    (reference "R6") (value "100k")
    (fp_text reference "R6" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "ADC_DP"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))
  (footprint "Capacitor_SMD:C_0805_2012Metric" (layer "F.Cu") (at 49 25.5)
    (reference "C_ADC3") (value "10nF")
    (fp_text reference "C_ADC3" (at 0 -1.5) (layer "F.SilkS") (effects (font (size 0.7 0.7))))
    (pad "1" smd rect (at -1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "ADC_DP"))
    (pad "2" smd rect (at  1.1 0) (size 1.4 1.8) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "GND")))

  ;; CC1 divider
  (footprint "Resistor_SMD:R_0805_2012Metric" (layer "F.Cu") (at 45 31)

#!/usr/bin/env python3

import os
import sys
from datetime import datetime

TARGET_FILE = "/home/marctremb/org_notes/capturethis"
timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

# Support for piped input
if not sys.stdin.isatty():
    thought = sys.stdin.read().strip()
# Or passed as arguments
elif len(sys.argv) > 1:
    thought = " ".join(sys.argv[1:]).strip()
# Or interactive prompt
else:
    thought = input("Thought: ").strip()

if thought:
    with open(TARGET_FILE, "a") as f:
        f.write(f"* {timestamp}\n  {thought}\n\n")
    print("Captured.")
else:
    print("No input. Nothing saved.")

